@page "/addproduct"
@using Data.Models
@inject Data.DbContext Db
@inject NavigationManager Nav


<h3>Добавить товар</h3>

@if (categories.Count == 0)
{
    <p><em>Загрузка категорий...</em></p>
}
else
{
    <EditForm Model="@product" OnValidSubmit="@Save" FormName="AddProductForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Название товара:</label>
            <InputText @bind-Value="product.NameProduct" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Цена:</label>
            <InputNumber @bind-Value="product.Price" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Категория:</label>
            <InputSelect @bind-Value="selectedCategoryId" class="form-control" @typeparam="int">
                <option value="0">-- выберите категорию --</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.CategoryId">@cat.NameCategories</option>
                }
            </InputSelect>
        </div>

        <div class="form-check mb-3">
            <InputCheckbox @bind-Value="product.IsHidden" class="form-check-input" />
            <label class="form-check-label">Скрыть</label>
        </div>

        <button type="submit" class="btn btn-success">Сохранить</button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Отмена</button>
    </EditForm>
}

@code {
    Product product = new();
    List<Category> categories = new();
    int selectedCategoryId = 0;

    protected override async Task OnInitializedAsync()
    {
        categories = await Db.Categories.ToListAsync();
        StateHasChanged(); // обновляем интерфейс после загрузки
    }

    async Task Save()
    {
        Console.WriteLine($"Выбранная категория: {selectedCategoryId}");

        if (selectedCategoryId == 0)
        {
            Console.WriteLine("Категория не выбрана.");
            return;
        }

        product.CategoryId = selectedCategoryId;

        try
        {
            Db.Products.Add(product);
            await Db.SaveChangesAsync();
            Console.WriteLine("Товар сохранён");
            Nav.NavigateTo("/products");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при сохранении: {ex.Message}");
        }
    }

    void Cancel()
    {
        Nav.NavigateTo("/products");
    }
}
