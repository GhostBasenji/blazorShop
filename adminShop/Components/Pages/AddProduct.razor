@page "/addproduct"
@using ShopData.Models
@using ShopData.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ShopDbContext> DbFactory
@inject NavigationManager NavigationManager

<h3>Добавление нового товара</h3>

<div class="row mt-4">
    <div class="col-md-8">
        <EditForm Model="@newProduct" OnValidSubmit="HandleValidSubmit" FormName="AddProduct">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="productName" class="form-label">Название товара</label>
                <InputText id="productName" @bind-Value="newProduct.NameProduct" class="form-control" />
                <ValidationMessage For="@(() => newProduct.NameProduct)" />
            </div>

            <div class="mb-3">
                <label for="productPrice" class="form-label">Цена</label>
                <InputNumber id="productPrice" @bind-Value="newProduct.Price" class="form-control" />
                <ValidationMessage For="@(() => newProduct.Price)" />
            </div>

            <div class="mb-3">
                <label for="productCategory" class="form-label">Категория</label>
                <div class="d-flex">
                    <InputSelect id="productCategory" @bind-Value="newProduct.CategoryId" class="form-control">
                        <option value="0">-- Выберите категорию --</option>
                        @if (categories != null)
                        {
                            @foreach (var category in categories)
                            {
                                <option value="@category.CategoryId">@category.NameCategories</option>
                            }
                        }
                    </InputSelect>
                    <button type="button" class="btn btn-outline-secondary ms-2" @onclick="OpenAddCategoryModal">
                        <span class="oi oi-plus"></span> Новая категория
                    </button>
                </div>
                <ValidationMessage For="@(() => newProduct.CategoryId)" />
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="NavigateToProducts">Отмена</button>
            </div>
        </EditForm>
    </div>
</div>

@if (showAddCategoryModal)
{
    <div class="modal show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Добавление новой категории</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddCategoryModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@newCategory" OnValidSubmit="AddCategory">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="categoryName" class="form-label">Название категории</label>
                            <InputText id="categoryName" @bind-Value="newCategory.NameCategories" class="form-control" />
                            <ValidationMessage For="@(() => newCategory.NameCategories)" />
                        </div>

                        <div class="text-end">
                            <button type="button" class="btn btn-secondary" @onclick="CloseAddCategoryModal">Отмена</button>
                            <button type="submit" class="btn btn-primary ms-2">Добавить</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    private Product newProduct = new Product();
    private Category newCategory = new Category();
    private List<Category> categories;
    private bool showAddCategoryModal = false;
    private string errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();

        // Устанавливаем значение по умолчанию, чтобы избежать ошибки валидации при первой загрузке
        if (categories != null && categories.Any())
        {
            newProduct.CategoryId = categories.First().CategoryId;
        }
    }

    private async Task LoadCategories()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        categories = await context.Categories.OrderBy(c => c.NameCategories).ToListAsync();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            Console.WriteLine(">>> HandleValidSubmit вызван <<<");
            Console.WriteLine($"Название товара: '{newProduct.NameProduct}'");
            Console.WriteLine($"Цена: {newProduct.Price}");
            Console.WriteLine($"Категория ID: {newProduct.CategoryId}");

            if (string.IsNullOrWhiteSpace(newProduct.NameProduct))
            {
                errorMessage = "Название товара не может быть пустым.";
                return;
            }

            using var context = await DbFactory.CreateDbContextAsync();

            await context.Products.AddAsync(newProduct);
            Console.WriteLine("Товар добавлен в контекст.");

            await context.SaveChangesAsync();
            Console.WriteLine("Изменения сохранены в базе.");

            NavigateToProducts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при сохранении товара: {ex.Message}";
            Console.WriteLine($"Ошибка при сохранении товара: {ex.Message}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"Внутреннее исключение: {ex.InnerException.Message}");
            }
        }
    }

    private void NavigateToProducts()
    {
        NavigationManager.NavigateTo("/products");
    }

    private void OpenAddCategoryModal()
    {
        newCategory = new Category();
        showAddCategoryModal = true;
    }

    private void CloseAddCategoryModal()
    {
        showAddCategoryModal = false;
    }

    private async Task AddCategory()
    {
        try
        {
            Console.WriteLine(">>> AddCategory вызван <<<");
            Console.WriteLine($"Название категории: '{newCategory.NameCategories}'");

            if (string.IsNullOrWhiteSpace(newCategory.NameCategories))
            {
                errorMessage = "Название категории не может быть пустым.";
                return;
            }

            using var context = await DbFactory.CreateDbContextAsync();

            await context.Categories.AddAsync(newCategory);
            await context.SaveChangesAsync();

            await LoadCategories();

            // Устанавливаем выбранную категорию на только что созданную
            newProduct.CategoryId = newCategory.CategoryId;

            CloseAddCategoryModal();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при сохранении категории: {ex.Message}";
            Console.WriteLine($"Ошибка при сохранении категории: {ex.Message}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"Внутреннее исключение: {ex.InnerException.Message}");
            }
        }
    }
}