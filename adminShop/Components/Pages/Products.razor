@using Data.Models

@page "/products"
@inject Data.DbContext Db
@inject NavigationManager Nav

<h3>Список товаров</h3>

@if (products == null)
{
    <p>Загрузка...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Название</th>
                <th>Цена</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in products)
            {
                <tr>
                    <td>@p.NameProduct</td>
                    <td>@p.Price ₽</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="@(() => Nav.NavigateTo($"/editproduct/{p.ProductId}"))">
                            Изменить
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<Product> products = new();

    protected override void OnInitialized()
    {
        products = Db.Products.ToList();
    }

    void Delete(int id)
    {
        var product = Db.Products.Find(id);
        if (product is not null)
        {
            Db.Products.Remove(product);
            Db.SaveChanges();
            products.Remove(product);
        }
    }
}
