@page "/cart"
@using Data.Models
@inject Data.DbContext Db
@inject NavigationManager Nav

<h3>Ваша корзина</h3>

@if (cartItems.Count == 0)
{
    <p>Ваша корзина пуста.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Товар</th>
                <th>Цена</th>
                <th>Количество</th>
                <th>Итого</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in cartItems)
            {
                <tr>
                    <td>@item.Product.NameProduct</td>
                    <td>@item.Product.Price.ToString("C")</td>
                    <td>
                        <InputNumber @bind-Value="item.Quantity" min="1" class="form-control" />
                    </td>
                    <td>@(item.Product.Price * item.Quantity).ToString("C")</td>
                    <td>
                        <button class="btn btn-danger" @onclick="() => RemoveFromCart(item.ProductId)">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-primary" @onclick="Checkout">Оформить заказ</button>
}

@code {
    List<CartItem> cartItems = new List<CartItem>();

    protected override void OnInitialized()
    {
        // Загрузка товаров в корзине (например, из сессии или базы данных)
        cartItems = Db.CartItems.Include(ci => ci.Product).Where(ci => ci.CustomerId == currentCustomerId).ToList();
    }

    void RemoveFromCart(int productId)
    {
        var item = cartItems.FirstOrDefault(ci => ci.ProductId == productId);
        if (item != null)
        {
            Db.CartItems.Remove(item);
            Db.SaveChanges();
            cartItems.Remove(item);
        }
    }

    async Task Checkout()
    {
        var order = new Order
            {
                CustomerId = currentCustomerId,  // ID текущего клиента
                OrderDate = DateTime.Now,
                DeliveryAddress = "Адрес доставки клиента",  // Это может быть динамическим полем
            };

        Db.Orders.Add(order);
        await Db.SaveChangesAsync();

        foreach (var item in cartItems)
        {
            var orderItem = new OrderItem
                {
                    OrderId = order.OrderId,
                    ProductId = item.ProductId,
                    Quantity = item.Quantity
                };
            Db.OrderItems.Add(orderItem);
        }

        await Db.SaveChangesAsync();
        Nav.NavigateTo("/orders");  // Перенаправляем покупателя на страницу с заказами
    }
}
